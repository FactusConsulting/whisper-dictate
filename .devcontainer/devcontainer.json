{
  "name": "whisper-dictate",
  "build": { "dockerfile": "Dockerfile" },
  "postCreateCommand": "rustup show && cargo fetch --manifest-path src/rust/Cargo.toml",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "ms-python.python",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "rust-analyzer.linkedProjects": ["src/rust/Cargo.toml"]
      }
    }
  }
}
