# Python venvs (machine-local — rebuilt by setup.ps1)
.venv/
.codex-test-venv/
venv/
whisper-dictate-venv/
voice-pi-venv/

# Python bytecode
__pycache__/
*.py[cod]
.pytest_cache/

# Rust build output
target/
target-clippy/

# Coverage + Clippy reports generated in CI for SonarQube import
clippy-report.json
coverage.xml
lcov.info
.coverage

# Local installer/ZIP build output
Output/

# Model cache (fetched at runtime into the HF cache, never vendored)
.cache/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/
!.vscode/settings.json

# Claude Code settings (personal, machine-local — never commit)
.claude/
.codex/

# Local benchmark recordings/results
benchmark/audio/
benchmark/*.jsonl

# Devcontainer-side cargo + rustup + target caches written by
# scripts/dev/dev-check.ps1 (the Linux target dir is shared via the
# mounted repo so the host doesn't need a separate clippy toolchain;
# keep all three out of git).
/.cargo-cache/
/.rustup-cache/
/target-linux/
